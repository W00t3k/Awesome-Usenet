#!/usr/bin/env bash
# Majic Movie Selector – macOS app launcher
set -euo pipefail

# Resolve the project directory (two levels up from Contents/MacOS/)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"

cd "$PROJECT_DIR"

# Activate venv if present
if [ -f ".venv/bin/activate" ]; then
    source ".venv/bin/activate"
fi

# Check Python
if ! command -v python3 &>/dev/null; then
    osascript -e 'display alert "Python 3 not found" message "Install Python 3.11+ from python.org then re-run the installer." as critical'
    exit 1
fi

# Install deps if first launch (no venv yet)
if [ ! -f ".venv/bin/activate" ]; then
    osascript -e 'display notification "Setting up Majic on first launch…" with title "Majic Movie Selector"'
    python3 -m venv .venv
    source ".venv/bin/activate"
    pip install -q -e .
fi

exec python3 desktop_app.py
